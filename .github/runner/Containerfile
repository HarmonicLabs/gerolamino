FROM docker.io/archlinux/archlinux:latest

# Only curl needed from pacman — everything else via Nix
RUN pacman -Sy --noconfirm curl && pacman -Scc --noconfirm

# Install Determinate Nix (root-only, sandbox disabled for containers)
RUN curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix | \
    sh -s -- install linux --init none --extra-conf "sandbox = false" --no-confirm

ENV PATH="/nix/var/nix/profiles/default/bin:/root/.nix-profile/bin:${PATH}"

# Point default nixpkgs to unstable
RUN nix registry add nixpkgs github:NixOS/nixpkgs/nixos-unstable

# All CI tools from Nix (nixpkgs-unstable)
RUN nix profile install nixpkgs#nodejs nixpkgs#bun nixpkgs#git nixpkgs#openssh nixpkgs#coreutils nixpkgs#bash

# Verify
RUN nix --version && node --version && bun --version && git --version && ssh -V

WORKDIR /workspace
