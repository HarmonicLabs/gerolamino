# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.nx/
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

.claude/worktrees
.claude/settings.local.json

# Nix / devenv
.direnv/
.devenv
.envrc.local
result
result-*

# Rust build artifacts
target/
*.wasm

# tsgo incremental build artifacts (per-developer paths, stale state)
*.tsbuildinfo

# Stale tsgo/tsc declaration artifacts emitted into src/ directories.
# `tsconfig.lib.json` has `outDir: "./dist"` but past build configs routed
# declarations next to sources. Path aliases resolve to `.ts` files, so these
# are derived noise — never commit them.
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
apps/*/src/**/*.d.ts
apps/*/src/**/*.d.ts.map

# Mithril snapshot databases (not source code db/ directories)
apps/bootstrap/db
.secrets

# WASM build outputs (generated by Nix)
packages/wasm-plexer/result/
packages/wasm-utils/pkg/

# Playwright artefacts (chrome-ext e2e)
packages/chrome-ext/test-results/
packages/chrome-ext/playwright-report/
packages/chrome-ext/.output/

# Dashboard SPA build (consumed by apps/tui's Bun.WebView path)
packages/dashboard/dist-spa/
packages/dashboard/dist/
