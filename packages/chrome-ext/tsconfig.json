{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "types": ["chrome", "bun"],
    "paths": {
      "@": [".."],
      "@/*": ["../*"],
      "~": [".."],
      "~/*": ["../*"],
      "@@": [".."],
      "@@/*": ["../*"],
      "~~": [".."],
      "~~/*": ["../*"],
      "consensus": ["../consensus/src/index.ts"],
      "consensus/*": ["../consensus/src/*"],
      "storage": ["../storage/src/index.ts"],
      "storage/*": ["../storage/src/*"],
      "ledger": ["../ledger/src/index.ts"],
      "ledger/*": ["../ledger/src/*"],
      "miniprotocols": ["../miniprotocols/src/index.ts"],
      "miniprotocols/*": ["../miniprotocols/src/*"],
      "bootstrap": ["../bootstrap/src/index.ts"],
      "bootstrap/*": ["../bootstrap/src/*"],
      "dashboard": ["../dashboard/src/index.ts"],
      "dashboard/*": ["../dashboard/src/*"],
      "cbor-schema": ["../cbor-schema/src/index.ts"],
      "cbor-schema/*": ["../cbor-schema/src/*"],
      "wasm-utils": ["../wasm-utils/pkg/wasm_utils.js"],
      "wasm-plexer": ["../wasm-plexer/result/wasm_plexer_bun.js"]
    }
  },
  "references": [
    {
      "path": "../dashboard/tsconfig.lib.json"
    }
  ]
}
