{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "types": ["chrome", "bun"],
    // `customConditions` lets `package.json#exports` resolve workspace
    // packages (wasm-utils, wasm-plexer, lsm-ffi) to their `@org/source`
    // entry (the `./src/index.ts` TS source) instead of any built
    // artefact that might not carry the full named-export surface.
    // Mirrors the setting in `tsconfig.base.json`.
    "customConditions": ["@org/source"],
    "paths": {
      "@": ["./.."],
      "@/*": ["./../*"],
      "~": ["./.."],
      "~/*": ["./../*"],
      "@@": ["./.."],
      "@@/*": ["./../*"],
      "~~": ["./.."],
      "~~/*": ["./../*"],
      "consensus": ["./../consensus/src/index.ts"],
      "consensus/*": ["./../consensus/src/*"],
      "ffi": ["./../ffi/src/index.ts"],
      "ffi/*": ["./../ffi/src/*"],
      "storage": ["./../storage/src/index.ts"],
      "storage/*": ["./../storage/src/*"],
      "ledger": ["./../ledger/src/index.ts"],
      "ledger/*": ["./../ledger/src/*"],
      "miniprotocols": ["./../miniprotocols/src/index.ts"],
      "miniprotocols/*": ["./../miniprotocols/src/*"],
      "bootstrap": ["./../bootstrap/src/index.ts"],
      "bootstrap/*": ["./../bootstrap/src/*"],
      "dashboard": ["./../dashboard/src/index.ts"],
      "dashboard/*": ["./../dashboard/src/*"],
      "codecs": ["./../codecs/src/index.ts"],
      "codecs/*": ["./../codecs/src/*"],
      "wasm-utils": ["./../wasm-utils/src/index.ts"],
      "wasm-utils/*": ["./../wasm-utils/src/*"],
      "wasm-plexer": ["./../wasm-plexer/src/index.ts"],
      "wasm-plexer/*": ["./../wasm-plexer/src/*"]
    }
  },
  "references": [
    {
      "path": "../dashboard/tsconfig.lib.json"
    }
  ]
}
