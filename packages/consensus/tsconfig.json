{
  "compilerOptions": {
    "skipLibCheck": true,
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext"],
    "moduleResolution": "bundler",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "storage/*": ["../storage/src/*"],
      "ledger/*": ["../ledger/src/*"],
      "cbor-schema/*": ["../cbor-schema/src/*"],
      "wasm-utils": ["../wasm-utils/pkg/wasm_utils.js"]
    }
  },
  "include": ["./src/**/*.ts", "../../node_modules/@types/bun/index.d.ts"],
  "exclude": ["dist", "node_modules"]
}
