{
  "name": "wasm-utils",
  "version": "0.1.0",
  "private": true,
  "description": "WASM utility bindings for Cardano primitives (Pallas crypto, addresses)",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "@org/source": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./pkg/*": "./pkg/*",
    "./*": "./src/*"
  },
  "scripts": {
    "type-check": "tsgo --noEmit -p tsconfig.json"
  }
}
