{
  "compilerOptions": {
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["esnext", "dom"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext",
    "types": ["bun"],
    "customConditions": ["@org/source"],
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnostics": true,
        "refactors": true,
        "completions": true
      }
    ],
    "paths": {
      "codecs": ["./packages/codecs/src/index.ts"],
      "codecs/*": ["./packages/codecs/src/*"],
      "ledger": ["./packages/ledger/src/index.ts"],
      "ledger/*": ["./packages/ledger/src/*"],
      "storage": ["./packages/storage/src/index.ts"],
      "storage/*": ["./packages/storage/src/*"],
      "miniprotocols": ["./packages/miniprotocols/src/index.ts"],
      "miniprotocols/*": ["./packages/miniprotocols/src/*"],
      "bootstrap": ["./packages/bootstrap/src/index.ts"],
      "bootstrap/*": ["./packages/bootstrap/src/*"],
      "wasm-utils": ["./packages/wasm-utils/src/index.ts"],
      "wasm-utils/*": ["./packages/wasm-utils/src/*"],
      "wasm-plexer": ["./packages/wasm-plexer/src/index.ts"],
      "wasm-plexer/*": ["./packages/wasm-plexer/src/*"],
      "lsm-ffi": ["./packages/ffi/src/index.ts"],
      "lsm-ffi/*": ["./packages/ffi/src/*"],
      "consensus": ["./packages/consensus/src/index.ts"],
      "consensus/*": ["./packages/consensus/src/*"],
      "dashboard": ["./packages/dashboard/src/index.ts"],
      "dashboard/*": ["./packages/dashboard/src/*"]
    }
  }
}
