{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["esnext", "dom"],
    "module": "preserve",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext",
    "customConditions": ["@org/source"],
    "plugins": [
      {
        "name": "@effect/language-service",
        "diagnostics": true,
        "refactors": true,
        "completions": true
      }
    ],
    "paths": {
      "codecs": ["./packages/codecs/src/index.ts"],
      "codecs/*": ["./packages/codecs/src/*"],
      "ledger": ["./packages/ledger/src/index.ts"],
      "ledger/*": ["./packages/ledger/src/*"],
      "storage": ["./packages/storage/src/index.ts"],
      "storage/*": ["./packages/storage/src/*"],
      "miniprotocols": ["./packages/miniprotocols/src/index.ts"],
      "miniprotocols/*": ["./packages/miniprotocols/src/*"],
      "bootstrap": ["./packages/bootstrap/src/index.ts"],
      "bootstrap/*": ["./packages/bootstrap/src/*"],
      "wasm-utils": ["./packages/wasm-utils/pkg/wasm_utils.js"],
      "wasm-plexer": ["./packages/wasm-plexer/result/wasm_plexer_bun.js"],
      "lsm-tree": ["./packages/lsm-tree/src/index.ts"],
      "lsm-tree/*": ["./packages/lsm-tree/src/*"],
      "consensus": ["./packages/consensus/src/index.ts"],
      "consensus/*": ["./packages/consensus/src/*"],
      "dashboard": ["./packages/dashboard/src/index.ts"],
      "dashboard/*": ["./packages/dashboard/src/*"]
    }
  }
}
